// =============================================================================
// WEELO BACKEND - PRISMA SCHEMA (Production Ready)
// =============================================================================
// 
// ARCHITECTURE:
// - Customer App (Weelo): Customers create orders, track shipments
// - Captain App (Weelo Captain): Transporters & Drivers manage fleet, accept trips
// 
// DATA SEPARATION:
// - Users are separated by 'role' field (customer | transporter | driver)
// - Customers can ONLY see their own orders
// - Transporters can ONLY see their own vehicles, drivers, assignments
// - Drivers can ONLY see their own trips
// 
// SCALABILITY:
// - Indexes on all foreign keys and frequently queried fields
// - Composite indexes for common query patterns
// - Optimized for millions of users
// 
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS - Defined types for consistency
// =============================================================================

// User roles - determines which app they use
enum UserRole {
  customer    // Uses Customer App (Weelo) - creates orders
  transporter // Uses Captain App - manages fleet, accepts orders
  driver      // Uses Captain App - drives trucks, completes trips
}

// Vehicle operational status
enum VehicleStatus {
  available   // Ready for new trips
  on_hold    // Reserved while driver decides
  in_transit  // Currently on a trip
  maintenance // Under maintenance
  inactive    // Not operational
}

/// Booking lifecycle (legacy single-truck). Intentionally separate from OrderStatus.
enum BookingStatus {
  created          // Initial state before broadcasting
  broadcasting     // Actively sending to transporters
  active           // Looking for transporters (awaiting responses)
  partially_filled // Some trucks assigned
  fully_filled     // All trucks assigned
  in_progress      // Trip started
  completed        // Trip completed
  cancelled        // Cancelled by customer
  expired          // No transporter accepted in time
}

/// Order lifecycle (multi-truck). Intentionally separate from BookingStatus.
enum OrderStatus {
  created          // Initial state before broadcasting
  broadcasting     // Actively sending to transporters
  active           // Looking for transporters (awaiting responses)
  partially_filled // Some trucks assigned
  fully_filled     // All trucks assigned
  in_progress      // Trip started
  completed        // Trip completed
  cancelled        // Cancelled by customer
  expired          // No transporter accepted in time
}

// Individual truck request status within an order
enum TruckRequestStatus {
  searching   // Looking for transporter
  held        // Temporarily held by transporter (15 sec timer)
  assigned    // Confirmed, waiting for driver
  accepted    // Driver accepted
  in_progress // Trip in progress
  completed   // Trip completed
  cancelled   // Cancelled
  expired     // Hold/search expired
}

// Assignment/Trip status
// L-17: partial_delivery added. Run SQL on production DB:
//   ALTER TYPE "AssignmentStatus" ADD VALUE 'partial_delivery';
enum AssignmentStatus {
  pending            // Waiting for driver to accept
  driver_accepted    // Driver accepted the trip
  driver_declined    // Driver declined
  en_route_pickup    // Driver heading to pickup
  at_pickup          // Driver arrived at pickup
  in_transit         // Goods loaded, heading to drop
  arrived_at_drop    // Driver arrived at drop-off location
  completed          // Trip completed
  partial_delivery   // L-17: Trip partially delivered (driver reported reason)
  cancelled          // Trip cancelled
}

// Route point type for multi-stop orders
enum RoutePointType {
  PICKUP // Starting point
  STOP   // Intermediate stop
  DROP   // Final destination
}

// =============================================================================
// TWO-PHASE TRUCK HOLD SYSTEM (PRD 7777)
// =============================================================================

// Hold phase for two-phase hold system
enum HoldPhase {
  FLEX       // Phase 1: 90s base, can be extended (max 130s total)
  CONFIRMED  // Phase 2: Trucks locked, max 180s from confirmation
  EXPIRED    // Hold expired
  RELEASED   // Hold released by transporter
}

// Timeout extension type for tracking
enum TimeoutExtensionType {
  BASE          // Initial 120s timeout
  FIRST_DRIVER  // +60s extension on first driver confirmation
  SUBSEQUENT    // +30s extension on each subsequent driver
  NO_PROGRESS   // Reset on no progress (for recovery)
}

// F-B-75: KYC FSM. Kept in sync with the legacy `isVerified` boolean by admin
// flows; broadcast filter at order-broadcast.service.ts requires VERIFIED.
enum KycStatus {
  NOT_STARTED   // No KYC submitted yet (default)
  UNDER_REVIEW  // Documents uploaded, pending admin review
  VERIFIED      // KYC passed — eligible for broadcast
  REJECTED      // KYC failed — not eligible, must re-submit
  EXPIRED       // Previously verified, documents expired — must re-verify
}

// =============================================================================
// USER MODEL
// =============================================================================
// 
// SEPARATION BY ROLE:
// - customer: Uses Customer App, creates orders
// - transporter: Uses Captain App, manages fleet
// - driver: Uses Captain App, assigned by transporter
// 
// UNIQUE CONSTRAINT: phone + role (same phone can be customer AND transporter)
// =============================================================================

model User {
  id           String   @id @default(uuid())
  phone        String   // Phone number (with country code)
  role         UserRole // Determines which app they use
  name         String
  email        String?
  profilePhoto String?

  // =========================================
  // CUSTOMER SPECIFIC FIELDS
  // =========================================
  company   String? // Company name
  gstNumber String? // GST number for invoicing

  // =========================================
  // TRANSPORTER SPECIFIC FIELDS
  // =========================================
  businessName    String? // Fleet/Business name
  businessAddress String?
  panNumber       String?

  // =========================================
  // DRIVER SPECIFIC FIELDS
  // =========================================
  transporterId String? // Which transporter this driver works for
  transporter   User?   @relation("TransporterDrivers", fields: [transporterId], references: [id])
  drivers       User[]  @relation("TransporterDrivers")
  licenseNumber String?
  licenseExpiry String?
  aadharNumber  String?

  // Driver profile completion fields
  address              String?
  preferredVehicleType String?
  preferredLanguage    String?  // null = not yet selected → shows language screen
  licenseFrontPhoto    String?  // S3 URL
  licenseBackPhoto     String?  // S3 URL
  isProfileCompleted   Boolean  @default(false)

  // =========================================
  // STATUS FLAGS
  // =========================================
  isVerified  Boolean   @default(false) // KYC verified (legacy boolean; kept in sync with kycStatus='VERIFIED' by admin flows)
  kycStatus   KycStatus @default(NOT_STARTED) // F-B-75: explicit KYC FSM — broadcasts only VERIFIED
  isActive    Boolean   @default(true)  // Account active
  isAvailable Boolean?  @default(true)  // Available for new orders (transporter/driver)

  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =========================================
  // RELATIONS
  // =========================================
  // Transporter relations
  vehicles Vehicle[] @relation("TransporterVehicles")

  // Driver relations  
  assignedVehicles Vehicle[] @relation("DriverVehicles")

  // Customer relations
  bookings Booking[] @relation("CustomerBookings")
  orders   Order[]   @relation("CustomerOrders")

  // Assignment relations
  transporterAssignments Assignment[] @relation("TransporterAssignments")
  driverAssignments      Assignment[] @relation("DriverAssignments")

  // Tracking relations
  trackingRecords Tracking[] @relation("DriverTracking")

  // TruckRequest relations
  heldTruckRequests           TruckRequest[] @relation("HeldByTransporter")
  assignedTruckRequests       TruckRequest[] @relation("AssignedTransporter")
  driverAssignedTruckRequests TruckRequest[] @relation("AssignedDriver")

  // Customer wallet and settings (for customer role only)
  wallet   Wallet?           @relation("UserWallet")
  settings CustomerSettings? @relation("UserSettings")

  // Rating relations
  ratingsGiven    Rating[] @relation("CustomerRatings")   // Ratings this user gave (as customer)
  ratingsReceived Rating[] @relation("DriverRatings")     // Ratings this user received (as driver)
  avgRating       Float?   // Denormalized: cached average rating (updated on each new rating)
  totalRatings    Int      @default(0) // Total number of ratings received as driver

  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@unique([phone, role]) // Same phone can have different roles
  @@index([role])         // Fast filtering by role
  @@index([transporterId]) // Fast lookup of drivers by transporter
  @@index([isActive, role]) // Active users by role
  @@index([phone])        // Fast phone lookup
  @@index([createdAt])    // For sorting/pagination
  // Phase-P1 | T1.4 | SC1 — broadcast KYC gate index. Mirrored in
  // prisma/manual-migrations/phase-p1-sc1-sc2-indexes.sql (direct psql —
  // NOT prisma migrate). Used by order-broadcast.service.ts KYC filter:
  // User WHERE id IN (...) AND isActive AND isVerified AND kycStatus='VERIFIED'.
  @@index([kycStatus, isVerified, isActive], map: "idx_user_kyc_broadcast")
}

// =============================================================================
// VEHICLE MODEL
// =============================================================================
// 
// Owned by TRANSPORTER, optionally assigned to DRIVER
// Used for matching customer orders to available trucks
// =============================================================================

model Vehicle {
  id               String  @id @default(uuid())
  transporterId    String  // Owner transporter
  transporter      User    @relation("TransporterVehicles", fields: [transporterId], references: [id])
  assignedDriverId String? // Currently assigned driver
  assignedDriver   User?   @relation("DriverVehicles", fields: [assignedDriverId], references: [id])

  // =========================================
  // VEHICLE IDENTIFICATION
  // =========================================
  vehicleNumber  String  @unique // e.g., "MH12AB1234"
  vehicleType    String  // e.g., "Open", "Container", "Tipper"
  vehicleSubtype String  // e.g., "17ft", "20-24 Ton"
  vehicleKey     String? // Normalized key for fast matching
  capacity       String  // e.g., "24 Ton"
  model          String? // e.g., "Tata Prima"
  year           Int?    // Manufacturing year

  // =========================================
  // STATUS TRACKING
  // =========================================
  status             VehicleStatus @default(available)
  currentTripId      String?       // If in_transit, which trip
  maintenanceReason  String?
  maintenanceEndDate String?
  lastStatusChange   String?

  // =========================================
  // DOCUMENTS
  // =========================================
  rcNumber        String?
  rcExpiry        String?
  insuranceNumber String?
  insuranceExpiry String?
  permitNumber    String?
  permitExpiry    String?
  fitnessExpiry   String?

  // =========================================
  // PHOTOS
  // =========================================
  vehiclePhotos  String[] @default([])
  rcPhoto        String?
  insurancePhoto String?

  // =========================================
  // STATUS FLAGS
  // =========================================
  isVerified Boolean @default(false)
  isActive   Boolean @default(true)

  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =========================================
  // RELATIONS
  // =========================================
  assignments   Assignment[]
  truckRequests TruckRequest[]

  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@index([transporterId])                    // Transporter's vehicles
  @@index([vehicleType, vehicleSubtype])      // Matching by type
  @@index([vehicleKey])                       // Fast normalized matching
  @@index([status])                           // Available vehicles
  @@index([isActive])                         // Active vehicles only
  @@index([status, isActive, vehicleType])    // Combined query optimization
  @@index([transporterId, status, isActive])  // Transporter's available trucks
  @@index([assignedDriverId])                 // M-13: Fast lookup by assigned driver
  // Phase-P1 | T1.4 | SC2 — DB-only partial index `idx_vehicle_key_avail`
  // on ("vehicleKey", "transporterId") WHERE "isActive"=true AND "status"='available'.
  // Prisma's schema DSL has no partial-index syntax, so this index lives in
  // prisma/manual-migrations/phase-p1-sc1-sc2-indexes.sql (direct psql — NOT
  // prisma migrate). Used by vehicle.repository.ts `vehicleKey IN (...)` +
  // hot-path filter to skip heap scans on dispatch fanout.
}

// =============================================================================
// BOOKING MODEL (Legacy - Single Truck)
// =============================================================================
// 
// Created by CUSTOMER from Customer App
// For backward compatibility with single-truck bookings
// =============================================================================

model Booking {
  id            String @id @default(uuid())
  customerId    String
  customer      User   @relation("CustomerBookings", fields: [customerId], references: [id])
  customerName  String
  customerPhone String

  // =========================================
  // LOCATIONS (JSON for flexibility)
  // =========================================
  pickup Json // { latitude, longitude, address, city?, state? }
  drop   Json // { latitude, longitude, address, city?, state? }

  // =========================================
  // REQUIREMENTS
  // =========================================
  vehicleType    String
  vehicleSubtype String
  trucksNeeded   Int
  trucksFilled   Int    @default(0)
  distanceKm     Float
  pricePerTruck  Float
  totalAmount    Float

  // =========================================
  // GOODS INFO
  // =========================================
  goodsType String?
  weight    String?

  // =========================================
  // STATUS
  // =========================================
  status         BookingStatus @default(active)
  stateChangedAt DateTime?     @default(now()) // Timestamp of last state transition

  // =========================================
  // BROADCAST TRACKING
  // =========================================
  notifiedTransporters String[] @default([])

  // =========================================
  // TIMING
  // =========================================
  scheduledAt String?
  expiresAt   String

  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =========================================
  // RELATIONS
  // =========================================
  assignments     Assignment[]
  trackingRecords Tracking[]

  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@index([customerId])                  // Customer's bookings
  @@index([status])                      // Active bookings
  @@index([vehicleType, vehicleSubtype]) // Matching
  @@index([createdAt])                   // Recent bookings
  @@index([customerId, status])          // Customer's active bookings
  @@index([status, vehicleType])         // Transporter feed: status + vehicle type filter
  @@index([notifiedTransporters], type: Gin) // M-12: Fast membership lookup for broadcast filtering
}

// =============================================================================
// ORDER MODEL (New - Multi Truck)
// =============================================================================
// 
// Created by CUSTOMER from Customer App
// Supports multiple trucks, intermediate stops
// =============================================================================

model Order {
  id            String @id @default(uuid())
  customerId    String
  customer      User   @relation("CustomerOrders", fields: [customerId], references: [id])
  customerName  String
  customerPhone String

  // =========================================
  // ROUTE (Multi-stop support)
  // =========================================
  routePoints       Json @default("[]") // RoutePointRecord[]
  currentRouteIndex Int  @default(0)    // Progress through route
  stopWaitTimers    Json @default("[]") // Wait time at each stop

  // =========================================
  // LOCATIONS (Quick access)
  // =========================================
  pickup Json // First point
  drop   Json // Last point

  // =========================================
  // ORDER SUMMARY
  // =========================================
  distanceKm   Float
  totalTrucks  Int   // Total trucks requested
  trucksFilled Int   @default(0)
  totalAmount  Float

  // =========================================
  // GOODS INFO
  // =========================================
  goodsType     String?
  weight        String?
  cargoWeightKg Float?

  // =========================================
  // STATUS
  // =========================================
  status         OrderStatus @default(active)
  stateChangedAt DateTime?   @default(now()) // Timestamp of last state transition

  // =========================================
  // DISPATCH OBSERVABILITY (Create/Broadcast lifecycle)
  // =========================================
  dispatchState         String   @default("queued") // queued|dispatching|dispatched|dispatch_failed
  dispatchAttempts      Int      @default(0)
  dispatchReasonCode    String?
  onlineCandidatesCount Int      @default(0)
  notifiedCount         Int      @default(0)
  lastDispatchAt        DateTime?

  // =========================================
  // CANCELLATION
  // =========================================
  cancelledAt        String?
  cancellationReason String?
  loadingStartedAt   DateTime?
  unloadingStartedAt DateTime?
  lifecycleEventVersion Int @default(0)

  // =========================================
  // TIMING
  // =========================================
  scheduledAt String?
  expiresAt   String

  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =========================================
  // RELATIONS
  // =========================================
  truckRequests TruckRequest[]
  assignments   Assignment[]
  timeout       OrderTimeout? @relation("OrderTimeoutLink", fields: [id], references: [orderId])

  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@index([customerId])         // Customer's orders
  @@index([status])             // Active orders
  @@index([createdAt])          // Recent orders
  @@index([customerId, status]) // Customer's active orders
  @@index([expiresAt])          // Expiring orders cleanup
  @@index([dispatchState, createdAt])
  // M-9: Composite index for active order lookups by customer (getActiveOrderByCustomer)
  @@index([customerId, status, expiresAt])
  // L-1: Composite index for expiry sweep queries (cleanup-expired-orders.job)
  @@index([status, expiresAt])

  // H3: DB-level guarantee: one active order per customer (partial unique index)
  // Allows multiple completed/cancelled/expired rows, but only ONE active order.
  // NOTE: Applied via direct SQL (see database-indexes.sql). Prisma cannot express partial indexes.
  // The actual DB constraint is: UNIQUE(customerId) WHERE status NOT IN ('completed','cancelled','expired')
}

// =============================================================================
// ORDER IDEMPOTENCY (DB source of truth for duplicate-safe retries)
// =============================================================================
model OrderIdempotency {
  id             String   @id @default(uuid())
  customerId     String
  idempotencyKey String
  payloadHash    String
  orderId        String
  responseJson   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([customerId, idempotencyKey])
  @@index([customerId, createdAt])
  @@index([orderId])
}

// =============================================================================
// ORDER DISPATCH OUTBOX (durable broadcast replay)
// =============================================================================
model OrderDispatchOutbox {
  id          String   @id @default(uuid())
  orderId     String   @unique
  payload     Json
  status      String   @default("pending") // pending|processing|retrying|dispatched|failed
  attempts    Int      @default(0)
  maxAttempts Int      @default(8)
  nextRetryAt DateTime @default(now())
  lockedAt    DateTime?
  processedAt DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, nextRetryAt, createdAt])
  @@index([orderId, status])
}

// =============================================================================
// ORDER LIFECYCLE OUTBOX (durable cancel fanout replay)
// =============================================================================
model OrderLifecycleOutbox {
  id            String   @id @default(uuid())
  orderId        String
  eventType      String   // order_cancelled|order_expired|...
  payload        Json
  status         String   @default("pending") // pending|processing|retrying|dispatched|failed
  attempts       Int      @default(0)
  maxAttempts    Int      @default(10)
  nextRetryAt    DateTime @default(now())
  lockedAt       DateTime?
  processedAt    DateTime?
  lastError      String?
  dlqReason      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId, eventType, status])
  @@index([status, nextRetryAt, createdAt])
}

// =============================================================================
// ORDER CANCEL IDEMPOTENCY (duplicate-safe cancel retries)
// =============================================================================
model OrderCancelIdempotency {
  id             String   @id @default(uuid())
  customerId     String
  operation      String   @default("cancel")
  idempotencyKey String
  payloadHash    String
  orderId        String
  statusCode     Int
  responseJson   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([customerId, operation, idempotencyKey])
  @@index([customerId, createdAt])
  @@index([orderId, createdAt])
}

// =============================================================================
// CANCELLATION LEDGER (policy + deferred settlement audit)
// =============================================================================
model CancellationLedger {
  id                    String   @id @default(uuid())
  orderId               String
  customerId            String
  driverId              String?
  policyStage           String
  reasonCode            String?
  penaltyAmount         Float    @default(0)
  compensationAmount    Float    @default(0)
  settlementState       String   @default("pending") // pending|settled|waived|disputed
  cancelDecision        String   @default("allowed") // allowed|blocked_dispute_only
  eventVersion          Int      @default(1)
  idempotencyKey        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orderId, createdAt])
  @@index([customerId, settlementState, createdAt])
}

// =============================================================================
// CUSTOMER PENALTY DUE (deferred charges)
// =============================================================================
model CustomerPenaltyDue {
  id            String   @id @default(uuid())
  customerId    String
  orderId       String
  amount        Float
  state         String   @default("due") // due|settled|waived|disputed
  nextOrderHint String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId, state, createdAt])
  @@index([orderId, state])
}

// =============================================================================
// DRIVER COMPENSATION LEDGER (deferred payouts)
// =============================================================================
model DriverCompensationLedger {
  id         String   @id @default(uuid())
  driverId   String
  orderId    String
  amount     Float
  state      String   @default("pending") // pending|posted|reversed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([driverId, state, createdAt])
  @@index([orderId, state])
}

// =============================================================================
// CANCELLATION ABUSE COUNTERS
// =============================================================================
model CancellationAbuseCounter {
  customerId                 String   @id
  cancelCount7d              Int      @default(0)
  cancelCount30d             Int      @default(0)
  cancelAfterLoadingCount    Int      @default(0)
  cancelRebook2mCount        Int      @default(0)
  cooldownUntil              DateTime?
  riskTier                   String   @default("normal")
  lastCancelAt               DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([customerId, updatedAt])
}

// =============================================================================
// CANCEL DISPUTE (blocked-stage cancel escalation)
// =============================================================================
model CancelDispute {
  id           String   @id @default(uuid())
  orderId       String
  customerId    String
  stage         String
  reasonCode    String?
  notes         String?
  status        String   @default("open") // open|under_review|resolved|rejected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId, createdAt])
  @@index([customerId, status, createdAt])
}

// =============================================================================
// TRUCK HOLD LEDGER (durable hold state for recovery and reconciliation)
// =============================================================================
// Updated for Two-Phase Hold System (PRD 7777)
// - Phase 1 (FLEX): 90s base, auto-extend +30s per driver, max 130s total
// - Phase 2 (CONFIRMED): Max 180s from confirmation, trucks locked
model TruckHoldLedger {
  holdId         String     @id
  orderId        String
  transporterId  String
  vehicleType    String
  vehicleSubtype String
  quantity       Int
  truckRequestIds String[]   @default([])

  // Legacy status field (for backward compatibility)
  status         String     @default("active") // active|confirmed|released|expired|cancelled

  // Two-Phase Hold System (NEW)
  phase          HoldPhase  @default(FLEX)     // FLEX → CONFIRMED → EXPIRED/RELEASED
  phaseChangedAt DateTime?                      // When phase last changed

  // Phase 1: FLEX Hold fields
  flexExpiresAt      DateTime?  // Phase 1 expiry time
  flexExtendedCount  Int        @default(0)  // Number of extensions used (max 3)

  // Phase 2: CONFIRMED Hold fields
  confirmedAt        DateTime?  // When moved to Phase 2
  confirmedExpiresAt DateTime?  // Phase 2 expiry time (max 180s from confirm)

  // Legacy fields (kept for backward compatibility)
  expiresAt      DateTime
  terminalReason String?
  releasedAt     DateTime?
  confirmedAtLegacy DateTime?  // Legacy field (use confirmedAt instead)

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([orderId, status, expiresAt])
  @@index([transporterId, status, expiresAt])
  @@index([phase, flexExpiresAt])
  @@index([phase, confirmedExpiresAt])
}

// =============================================================================
// TRUCK HOLD IDEMPOTENCY (duplicate-safe hold/release retries)
// =============================================================================
model TruckHoldIdempotency {
  id             String   @id @default(uuid())
  transporterId  String
  operation      String   // hold|release
  idempotencyKey String
  payloadHash    String
  statusCode     Int
  responseJson   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([transporterId, operation, idempotencyKey])
  @@index([transporterId, operation, createdAt])
}

// =============================================================================
// TWO-PHASE TRUCK HOLD NEW MODELS (PRD 7777)
// =============================================================================

// =============================================================================
// PROGRESS EVENT (for UI transparency - "+30s added" display)
// =============================================================================
// Tracks each driver acceptance that extends the order timeout
model ProgressEvent {
  id              String  @id @default(uuid())
  orderId         String
  orderTimeout    OrderTimeout @relation("OrderTimeoutProgress", fields: [orderId], references: [orderId], onDelete: Cascade)

  // Driver info
  driverId        String
  driverName      String

  // Extension details
  extensionType   TimeoutExtensionType
  addedSeconds    Int
  reason          String?

  // What triggered the extension
  trigger         String
  assignmentId    String?
  truckRequestId  String?

  timestamp       DateTime @default(now())

  @@index([orderId, timestamp])
  @@index([driverId])
}

// =============================================================================
// ORDER TIMEOUT TRACKING (PRD 7777 - Smart Timeout Extension)
// =============================================================================
// Tracks order timeout with smart extensions based on progress
model OrderTimeout {
  orderId         String   @id
  baseTimeoutMs   Int      @default(120000)
  extendedMs      Int      @default(0)
  lastProgressAt  DateTime?
  expiresAt       DateTime
  isExpired       Boolean  @default(false)
  expiredAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  progressEvents  ProgressEvent[] @relation("OrderTimeoutProgress")
  order           Order?   @relation("OrderTimeoutLink")

  @@index([expiresAt])
  @@index([isExpired])
}

// =============================================================================
// TRANSPORTER BROADCAST VIEW (for partial assignment visibility)
// =============================================================================
// Per-transporter view of broadcast with remaining trucks count
// Ensures new transporters see correct remaining count, not original total
model TransporterBroadcastView {
  id                String  @id @default(uuid())
  broadcastId       String
  transporterId     String

  // Vehicle availability as seen by this transporter
  vehicleType       String
  vehicleSubtype    String
  trucksNeeded      Int
  trucksAssigned    Int    @default(0)
  trucksRemaining   Int

  // Trucks assigned by others (for transparency)
  assignedByOthers  Json?

  // Tracking
  lastUpdateAt      DateTime @default(now())

  @@unique([broadcastId, transporterId])
  @@index([transporterId, lastUpdateAt])
  @@index([broadcastId, trucksRemaining])
}

// =============================================================================
// TRUCK REQUEST MODEL
// =============================================================================
// 
// Individual truck request within an Order
// Each truck in a multi-truck order has its own request
// =============================================================================

model TruckRequest {
  id            String @id @default(uuid())
  orderId       String
  order         Order  @relation(fields: [orderId], references: [id])
  requestNumber Int    // 1, 2, 3... within order

  // =========================================
  // VEHICLE REQUIREMENTS
  // =========================================
  vehicleType    String
  vehicleSubtype String
  pricePerTruck  Float

  // =========================================
  // STATUS
  // =========================================
  status TruckRequestStatus @default(searching)

  // =========================================
  // HOLD INFO (15 sec timer)
  // =========================================
  heldById String?
  heldBy   User?   @relation("HeldByTransporter", fields: [heldById], references: [id])
  heldAt   String?

  // =========================================
  // ASSIGNMENT INFO
  // =========================================
  assignedTransporterId   String?
  assignedTransporter     User?    @relation("AssignedTransporter", fields: [assignedTransporterId], references: [id])
  assignedTransporterName String?
  assignedVehicleId       String?
  assignedVehicle         Vehicle? @relation(fields: [assignedVehicleId], references: [id])
  assignedVehicleNumber   String?
  assignedDriverId        String?
  assignedDriver          User?    @relation("AssignedDriver", fields: [assignedDriverId], references: [id])
  assignedDriverName      String?
  assignedDriverPhone     String?

  // =========================================
  // TRACKING
  // =========================================
  tripId String?

  // =========================================
  // BROADCAST TRACKING
  // =========================================
  notifiedTransporters String[] @default([])

  // =========================================
  // TIMING
  // =========================================
  assignedAt String?

  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // =========================================
  // RELATIONS
  // =========================================
  assignments Assignment[]

  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@index([orderId])                       // Requests for an order
  @@index([status])                        // Searching requests
  @@index([vehicleType, vehicleSubtype])   // Matching
  @@index([heldById])                      // Held by transporter
  @@index([assignedTransporterId])         // Assigned to transporter
  @@index([status, vehicleType])           // Active requests by type
  @@index([notifiedTransporters], type: Gin) // Fast membership lookup for transporter feed
  @@index([orderId, vehicleType, vehicleSubtype, status, requestNumber])
  @@index([status, heldAt])
}

// =============================================================================
// ASSIGNMENT MODEL
// =============================================================================
// 
// Links: Customer Order -> Transporter -> Vehicle -> Driver
// Created when transporter accepts a truck request
// =============================================================================

model Assignment {
  id String @id @default(uuid())

  // =========================================
  // ORDER REFERENCE
  // =========================================
  bookingId      String?       // Legacy booking
  booking        Booking?      @relation(fields: [bookingId], references: [id])
  truckRequestId String?       // New truck request
  truckRequest   TruckRequest? @relation(fields: [truckRequestId], references: [id])
  orderId        String?       // Parent order
  order          Order?        @relation(fields: [orderId], references: [id])

  // =========================================
  // TRANSPORTER INFO
  // =========================================
  transporterId   String
  transporter     User   @relation("TransporterAssignments", fields: [transporterId], references: [id])
  transporterName String

  // =========================================
  // VEHICLE INFO
  // =========================================
  vehicleId      String
  vehicle        Vehicle @relation(fields: [vehicleId], references: [id])
  vehicleNumber  String
  vehicleType    String
  vehicleSubtype String

  // =========================================
  // DRIVER INFO
  // =========================================
  driverId    String
  driver      User   @relation("DriverAssignments", fields: [driverId], references: [id])
  driverName  String
  driverPhone String

  // =========================================
  // TRIP ID (Unique identifier for tracking)
  // =========================================
  tripId String @unique

  // =========================================
  // STATUS
  // =========================================
  status AssignmentStatus @default(pending)

  // =========================================
  // RATING (denormalized for fast trip list display)
  // =========================================
  customerRating Int?     // 1-5 stars (copied from Rating record for fast access)
  rating         Rating?  // Full rating record relation

  // =========================================
  // DECLINE TRACKING (H11 fix)
  // =========================================
  declineReason  String?    // Reason text (e.g., "too far", "wrong vehicle")
  declineType    String?    // Type: 'explicit' | 'timeout' | 'auto_system'
  declinedAt     DateTime?  // When the decline occurred

  // =========================================
  // TIMESTAMPS
  // =========================================
  assignedAt       String
  driverAcceptedAt String?
  startedAt        String?
  completedAt      String?

  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@index([bookingId])          // Assignments for booking
  @@index([truckRequestId])     // Assignment for truck request
  @@index([orderId])            // Assignments for order
  @@index([transporterId])      // Transporter's assignments
  @@index([driverId])           // Driver's assignments
  @@index([status])             // Active assignments
  @@index([driverId, status])   // Driver's active trips
  @@index([transporterId, status]) // Transporter's active assignments
  @@index([vehicleId, status])  // Phase 3: Watchdog — find active assignments per vehicle

  // DB-level guarantee: one active trip per driver (partial index)
  // Allows multiple completed/cancelled rows, but only ONE active assignment
  // NOTE: Applied via direct SQL. Prisma schema reflects the partial index for documentation.
  // The actual DB constraint is: UNIQUE(driverId) WHERE status NOT IN ('completed','cancelled','driver_declined')
  @@unique([driverId, status], map: "assignment_driver_active_unique")
}

// =============================================================================
// TRACKING MODEL
// =============================================================================
// 
// Real-time driver location updates
// Used by Customer App to track delivery
// =============================================================================

model Tracking {
  id            String   @id @default(uuid())
  tripId        String   @unique // One tracking per trip
  driverId      String
  driver        User     @relation("DriverTracking", fields: [driverId], references: [id])
  vehicleNumber String
  bookingId     String?
  booking       Booking? @relation(fields: [bookingId], references: [id])

  // =========================================
  // LOCATION DATA
  // =========================================
  latitude  Float
  longitude Float
  speed     Float @default(0)
  bearing   Float @default(0)
  status    String

  // =========================================
  // TIMESTAMPS
  // =========================================
  lastUpdated DateTime @default(now())

  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@index([tripId])     // Lookup by trip
  @@index([driverId])   // Driver's tracking
  @@index([bookingId])  // Tracking for booking
  @@index([lastUpdated]) // Recent updates
}

// =============================================================================
// WALLET MODEL - Customer wallet balance and transactions
// =============================================================================
// 
// SCALABILITY:
// - One wallet per customer
// - Indexed for fast balance lookups
// - Handles millions of transactions
// 
// EASY UNDERSTANDING:
// - Simple balance tracking
// - Clear transaction history
// 
// MODULARITY:
// - Separate from User model
// - Can be extended for payment gateway integration
// =============================================================================

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique // One wallet per customer
  user      User     @relation("UserWallet", fields: [userId], references: [id], onDelete: Cascade)
  balance   Float    @default(0) // Current wallet balance
  currency  String   @default("INR")
  
  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@index([userId]) // Fast wallet lookup
}

// =============================================================================
// CUSTOMER SETTINGS MODEL - App preferences and settings
// =============================================================================
// 
// SCALABILITY:
// - One settings record per customer
// - Cached in Redis for fast access
// 
// EASY UNDERSTANDING:
// - Clear boolean flags
// - Simple key-value structure
// 
// MODULARITY:
// - Separate from User model
// - Easy to add new settings
// 
// CODING STANDARDS:
// - Default values for all settings
// - Clear naming conventions
// =============================================================================

model CustomerSettings {
  id                    String   @id @default(uuid())
  userId                String   @unique // One settings record per customer
  user                  User     @relation("UserSettings", fields: [userId], references: [id], onDelete: Cascade)
  
  // =========================================
  // NOTIFICATION PREFERENCES
  // =========================================
  pushNotifications     Boolean  @default(true)
  smsNotifications      Boolean  @default(true)
  emailNotifications    Boolean  @default(false)
  
  // =========================================
  // APP PREFERENCES
  // =========================================
  language              String   @default("en") // en, hi, etc.
  theme                 String   @default("light") // light, dark
  
  // =========================================
  // VEHICLE TYPE FILTER (Rapido-style)
  // =========================================
  // Only: trucks, tractors, JCB, tempo (no bikes)
  preferredVehicleTypes String[] @default(["truck", "tractor", "jcb", "tempo"])
  
  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // =========================================
  // INDEXES FOR SCALABILITY
  // =========================================
  @@index([userId]) // Fast settings lookup
}

// =============================================================================
// CUSTOM BOOKING STATUS ENUM
// =============================================================================
// 
// Status flow: pending -> under_review -> approved/rejected -> completed
// Separate from instant booking flow
// =============================================================================

enum CustomBookingStatus {
  pending      // Awaiting review by team
  under_review // Being reviewed
  approved     // Approved, contacting customer
  rejected     // Request rejected
  completed    // Contract finalized
  cancelled    // Cancelled by customer
}

// =============================================================================
// CUSTOM BOOKING REQUEST MODEL
// =============================================================================
// 
// PURPOSE:
// - Long-term truck contracts (weeks/months)
// - Form submission that goes to review queue
// - Separate from instant Orders
// 
// SCALABILITY:
// - Indexed on common query patterns
// - Supports millions of concurrent requests
// - Optimized for admin filtering and search
// 
// MODULARITY:
// - Completely isolated from Order/Booking
// - Will be managed by separate admin app later
// 
// EASY UNDERSTANDING:
// - Clear field names
// - Comprehensive comments
// - Follows existing schema patterns
// =============================================================================

model CustomBookingRequest {
  id            String   @id @default(uuid())
  customerId    String   // Reference to User (customer role)
  customerName  String
  customerPhone String
  customerEmail String?
  companyName   String?  // Business name if applicable
  
  // =========================================
  // ROUTE DETAILS
  // =========================================
  pickupCity     String   // Starting city
  pickupState    String?  // Starting state
  dropCity       String   // Destination city
  dropState      String?  // Destination state
  additionalInfo String?  // Route notes
  
  // =========================================
  // VEHICLE REQUIREMENTS
  // =========================================
  // JSON array: [{ type: "Open", subtype: "17ft", quantity: 5 }, ...]
  vehicleRequirements Json
  totalTrucks         Int  // Sum of all quantities
  
  // =========================================
  // DURATION
  // =========================================
  startDate      String   // YYYY-MM-DD
  endDate        String   // YYYY-MM-DD
  durationMonths Int?     // Calculated months
  isFlexible     Boolean  @default(false) // Dates are flexible?
  
  // =========================================
  // GOODS INFORMATION
  // =========================================
  goodsType        String?  // Type of goods
  estimatedWeight  String?  // Weight per truck
  specialRequests  String?  // Free text for special requirements
  
  // =========================================
  // STATUS & REVIEW
  // =========================================
  status           CustomBookingStatus @default(pending)
  reviewNotes      String?  // Internal notes from reviewer
  reviewedBy       String?  // Admin/reviewer ID
  reviewedAt       String?  // When reviewed
  
  // =========================================
  // QUOTATION (After review)
  // =========================================
  quotedPrice      Float?   // Price quoted by team
  quotedAt         String?
  
  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // =========================================
  // INDEXES FOR SCALABILITY (Millions of requests)
  // =========================================
  @@index([customerId])           // Customer's requests
  @@index([status])               // Filter by status
  @@index([createdAt])            // Recent first
  @@index([status, createdAt])    // Admin dashboard query
  @@index([customerPhone])        // Search by phone
  @@index([pickupCity, dropCity]) // Route search
}

// =============================================================================
// RATING MODEL
// =============================================================================
//
// Customer rates driver after trip completion (per assignment, not per booking)
// One rating per customer per assignment (enforced by @@unique)
// Supports star rating (1-5), predefined tags, and optional comment
// =============================================================================

model Rating {
  id String @id @default(uuid())

  // =========================================
  // WHO RATED (customer)
  // =========================================
  customerId String
  customer   User   @relation("CustomerRatings", fields: [customerId], references: [id])

  // =========================================
  // WHO WAS RATED (driver)
  // =========================================
  driverId String
  driver   User   @relation("DriverRatings", fields: [driverId], references: [id])

  // =========================================
  // WHICH TRIP
  // =========================================
  assignmentId String     @unique // One rating per assignment
  assignment   Assignment @relation(fields: [assignmentId], references: [id])

  // Optional booking/order reference for analytics
  bookingId String?
  orderId   String?

  // =========================================
  // RATING DATA
  // =========================================
  stars   Int       // 1-5 star rating
  comment String?   // Optional text feedback (max 500 chars)
  tags    String[]  // Quick feedback tags: ["polite", "on_time", "safe_driving"]

  // =========================================
  // TIMESTAMPS
  // =========================================
  createdAt DateTime @default(now())

  // =========================================
  // CONSTRAINTS & INDEXES
  // =========================================
  @@unique([customerId, assignmentId]) // One rating per customer per trip
  @@index([driverId])                  // Fast driver rating lookup
  @@index([assignmentId])              // Fast trip rating lookup
  @@index([driverId, createdAt])       // Driver ratings over time (analytics)
  @@index([stars])                     // Rating distribution analytics
  @@index([customerId])               // Customer's given ratings
}

// =============================================================================
// DEVICE TOKEN MODEL (Fix H15: PostgreSQL fallback for FCM tokens)
// =============================================================================
// Primary FCM token storage is Redis (fast, shared across ECS instances).
// This table is a durable fallback: if Redis loses data (restart, eviction),
// tokens can be recovered from here so push notifications keep working.
//
// NOTE: Table must be created via direct SQL (per CLAUDE.md rules — no prisma migrate).
// CREATE TABLE "DeviceToken" (
//   "id" TEXT NOT NULL DEFAULT gen_random_uuid(),
//   "userId" TEXT NOT NULL,
//   "token" TEXT NOT NULL,
//   "platform" TEXT NOT NULL DEFAULT 'android',
//   "lastSeenAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
//   "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
//   CONSTRAINT "DeviceToken_pkey" PRIMARY KEY ("id")
// );
// CREATE UNIQUE INDEX "DeviceToken_userId_token_key" ON "DeviceToken"("userId", "token");
// CREATE INDEX "DeviceToken_userId_idx" ON "DeviceToken"("userId");
// =============================================================================

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String
  token      String
  platform   String   @default("android")
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([userId, token])
  @@index([userId])
}

// =============================================================================
// TRIP ROUTE POINT MODEL (H-23: GPS History DB Persistence)
// =============================================================================
// Persisted route points from Redis history list on trip completion.
// Allows post-trip route replay, analytics, and dispute evidence.
//
// NOTE: Table must be created via direct SQL (per CLAUDE.md rules — no prisma migrate).
// CREATE TABLE "TripRoutePoint" (
//   "id" TEXT NOT NULL DEFAULT gen_random_uuid(),
//   "tripId" TEXT NOT NULL,
//   "latitude" DOUBLE PRECISION NOT NULL,
//   "longitude" DOUBLE PRECISION NOT NULL,
//   "speed" DOUBLE PRECISION,
//   "heading" DOUBLE PRECISION,
//   "timestamp" TIMESTAMP(3) NOT NULL,
//   "createdAt" TIMESTAMP(3) NOT NULL DEFAULT CURRENT_TIMESTAMP,
//   CONSTRAINT "TripRoutePoint_pkey" PRIMARY KEY ("id")
// );
// CREATE INDEX "TripRoutePoint_tripId_timestamp_idx" ON "TripRoutePoint"("tripId", "timestamp");
// CREATE INDEX "TripRoutePoint_tripId_idx" ON "TripRoutePoint"("tripId");
// =============================================================================

model TripRoutePoint {
  id        String   @id @default(uuid())
  tripId    String
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  timestamp DateTime
  createdAt DateTime @default(now())

  @@index([tripId, timestamp])
  @@index([tripId])
}
